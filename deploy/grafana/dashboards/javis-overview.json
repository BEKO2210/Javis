{
  "title": "Javis — Overview",
  "uid": "javis-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["javis"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Brain — sentences",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "javis_brain_sentences" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Brain — words",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "javis_brain_words" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Token saving (lifetime, %)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - javis_recall_tokens_javis_total / javis_recall_tokens_rag_total)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "WebSocket sessions / sec by action",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (action) (rate(javis_ws_sessions_total[1m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p95 operation latency",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(javis_train_duration_seconds_bucket[5m])))",
          "legendFormat": "train p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(javis_recall_duration_seconds_bucket[5m])))",
          "legendFormat": "recall p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(javis_ask_duration_seconds_bucket[5m])))",
          "legendFormat": "ask p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
